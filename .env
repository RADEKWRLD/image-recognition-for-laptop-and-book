# ============ 路径配置 ============
DATA_DIR=data
OUT_DIR=runs

# ============ 训练超参(调参主要改这里; 报告 2.2/2.4 节实验记录即来自改本文件) ============
IMG_SIZE=96
BATCH_SIZE=16
EPOCHS=40
LR=0.0005
VAL_RATIO=0.2
SEED=42

# ============ CCT 结构超参(精简版 Compact Convolutional Transformer) ============
# 报告"结构参数调整过程"主要调这几项: token 维度 / Transformer 层数 / 注意力头数
EMBED_DIM=128
NUM_LAYERS=2
NUM_HEADS=4
MLP_RATIO=2.0
DROPOUT=0.1
